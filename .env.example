# ── Polymarket ────────────────────────────────────────────────────────────────
POLYMARKET_PRIVATE_KEY=your_private_key_here
POLYMARKET_FUNDER_ADDRESS=your_wallet_address_here

# ── Anthropic (προαιρετικό — AI confirmation) ─────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Bot Settings ──────────────────────────────────────────────────────────────
DRY_RUN=true           # true = paper trading, false = live (ΠΡΟΣΟΧΗ)

BANKROLL=100           # συνολικό κεφάλαιο σε USDC
KELLY_FRACTION=0.15    # 15% fractional Kelly (conservative)
MAX_BET_USDC=10        # hard cap ανά trade

MIN_EDGE=0.08          # ελάχιστο edge 8%
MIN_EV=0.03            # ελάχιστο expected value 3%
MIN_VOLUME=500         # skip markets με volume < $500

SCAN_INTERVAL=300      # seconds μεταξύ scans
